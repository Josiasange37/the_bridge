# TheBridge Server Configuration
NODE_ENV=production
SERVER_HOST=0.0.0.0
API_PORT=3000
WS_PORT=3001
SIGNALING_PORT=3002

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=thebridge
POSTGRES_USER=thebridge
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# MinIO File Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=thebridge
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=thebridge-files

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# TURN Server
TURN_SECRET=your_turn_secret_change_in_production
TURN_SERVER=turn:0.0.0.0:3478
STUN_SERVER=stun:0.0.0.0:3478

# mDNS Service Name
MDNS_SERVICE_NAME=thebridge
MDNS_SERVICE_TYPE=_thebridge._tcp

# File Transfer
MAX_FILE_SIZE=500MB
CHUNK_SIZE=1048576

# Security
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info
